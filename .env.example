# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Sinric Pro Configuration
SINRIC_APP_KEY=your_sinric_app_key_here
SINRIC_APP_SECRET=your_sinric_app_secret_here

# Device IDs (replace with your actual device IDs)
SINRIC_LIGHT_ID=your_light_device_id
SINRIC_BEDROOM_LIGHT_ID=your_bedroom_light_id
SINRIC_FAN_ID=your_fan_device_id
SINRIC_AC_ID=your_ac_device_id
SINRIC_TV_ID=your_tv_device_id

# Picovoice (Porcupine) Configuration
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# Voice Settings
TTS_RATE=180
TTS_VOLUME=0.9

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO